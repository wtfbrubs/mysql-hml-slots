# ── OCI credentials (não commitar valores reais) ──────────────────────────────
tenancy_ocid     = "ocid1.tenancy.oc1..xxxxxxxxxx"
user_ocid        = "ocid1.user.oc1..xxxxxxxxxx"
fingerprint      = "xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx"
private_key_path = "~/.oci/oci_api_key.pem"
region           = "sa-saopaulo-1"

compartment_ocid = "ocid1.compartment.oc1..xxxxxxxxxx"

# ── Network ───────────────────────────────────────────────────────────────────
allowed_cidr = "203.0.113.10/32"

# ── Compute HML host ──────────────────────────────────────────────────────────
compute_shape     = "VM.Standard.E4.Flex"
compute_ocpus     = 1
compute_memory_gb = 4
ssh_public_key    = "ssh-rsa AAAA..."

# URL do repositório para clone na instância
repo_url = "https://github.com/sua-org/mysql-hml-slots.git"

# Senha root do MySQL base no host HML
hml_mysql_root_password = "HmlRootSegura456!"

# ── HeatWave MySQL PRD ────────────────────────────────────────────────────────
mysql_shape          = "MySQL.VM.Standard.E4.1.8GB"
mysql_admin_user     = "admin"
mysql_admin_password = "SenhaSegura123!"
mysql_db_name        = "appdb"
