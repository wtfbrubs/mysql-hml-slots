# ── Modo OCI MySQL HeatWave ───────────────────────────────────────────────────
# PRD é um MySQL HeatWave na OCI. O host HML é uma Compute VM provisionada pelo
# Terraform em terraform/oci/. Após o terraform apply, o valor de PRD_HOST vem
# do output "mysql_prd_endpoint" e PRD_USER da variável mysql_admin_user.
# Este arquivo é gerado automaticamente pelo user_data da VM no primeiro boot.
# Use para configuração manual ou ajustes pós-provisionamento.

BASE_MYSQL_PORT=3306
BASE_MYSQL_ROOT_PASSWORD=<senha-root-hml>

MYSQL_VERSION=8.0

SLOTS_BASE_PORT=3310
SNAPSHOT_DIR=snapshots

# PRD remoto (OCI MySQL HeatWave)
PRD_MODE=remote
PRD_HOST=<hostname>.mysql.oraclecloud.com
PRD_PORT=3306
PRD_USER=admin
PRD_MYSQL_ROOT_PASSWORD=<senha-admin-heatwave>
PRD_SSL=true

# Replicação nativa PRD → base (make setup-replication)
# O usuário de replicação é criado no HeatWave pelo setup-replication.
REPLICATION_USER=hml_repl
REPLICATION_PASSWORD=<senha-replicacao>

# Clone Plugin base → slots (make setup-replication)
CLONE_USER=hml_clone
CLONE_PASSWORD=<senha-clone>

# Lag máximo aceitável antes de usar snapshot como fallback (segundos)
MAX_LAG_SECONDS=30
