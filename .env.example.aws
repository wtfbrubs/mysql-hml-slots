# ── Modo AWS RDS ──────────────────────────────────────────────────────────────
# PRD é um RDS MySQL 8.0. O host HML é uma EC2 provisionada pelo Terraform em
# terraform/aws/. Após o terraform apply, os valores de PRD_HOST e PRD_USER
# vêm do output "rds_prd_endpoint" e da variável db_username, respectivamente.
# Este arquivo é gerado automaticamente pelo user_data da EC2 no primeiro boot.
# Use para configuração manual ou ajustes pós-provisionamento.

BASE_MYSQL_PORT=3306
BASE_MYSQL_ROOT_PASSWORD=<senha-root-hml>

MYSQL_VERSION=8.0

SLOTS_BASE_PORT=3310
SNAPSHOT_DIR=snapshots

# PRD remoto (RDS MySQL 8.0)
PRD_MODE=remote
PRD_HOST=<identificador>.rds.amazonaws.com
PRD_PORT=3306
PRD_USER=admin
PRD_MYSQL_ROOT_PASSWORD=<senha-admin-rds>
PRD_SSL=true

# Replicação nativa PRD → base (make setup-replication)
# O usuário de replicação é criado no RDS pelo setup-replication.
REPLICATION_USER=hml_repl
REPLICATION_PASSWORD=<senha-replicacao>

# Clone Plugin base → slots (make setup-replication)
CLONE_USER=hml_clone
CLONE_PASSWORD=<senha-clone>

# Lag máximo aceitável antes de usar snapshot como fallback (segundos)
MAX_LAG_SECONDS=30
