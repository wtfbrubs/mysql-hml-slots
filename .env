BASE_MYSQL_PORT=3306
BASE_MYSQL_ROOT_PASSWORD=root123

MYSQL_VERSION=8.4

SLOTS_BASE_PORT=3310
SNAPSHOT_DIR=snapshots

# PRD local simulation
PRD_MYSQL_ROOT_PASSWORD=prd-root123
PRD_MYSQL_PORT=3307

# PRD_MODE: docker (container local) | remote (RDS/HeatWave)
PRD_MODE=docker

# Para PRD_MODE=remote, defina:
# PRD_HOST=rds-endpoint.region.rds.amazonaws.com
# PRD_PORT=3306
# PRD_USER=admin
# PRD_MYSQL_ROOT_PASSWORD=<senha-rds>

# Replicação nativa (make setup-replication)
REPLICATION_USER=hml_repl
REPLICATION_PASSWORD=repl-secret-change-me

# Clone Plugin para criação de slots (make setup-replication)
CLONE_USER=hml_clone
CLONE_PASSWORD=clone-secret-change-me

# Lag máximo aceitável antes de snapshot (segundos)
MAX_LAG_SECONDS=30
